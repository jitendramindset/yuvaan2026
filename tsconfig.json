{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "kernel/**/*.ts",
    "api/**/*.ts",
    "storage/**/*.ts",
    "backup/**/*.ts",
    "config/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}