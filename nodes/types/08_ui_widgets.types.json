{
  "_meta": {
    "category": "UI & Widget",
    "group": 8,
    "count": 12,
    "description": "Every rendered UI element is a widget node. The kernel's ui.generator.ts and customization.engine.ts create and manage these. Custom logic in widgets must be JavaScript."
  },
  "engine_files": ["kernel/ui.generator.ts","kernel/customization.engine.ts"],
  "types": [
